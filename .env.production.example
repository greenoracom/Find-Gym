NODE_ENV=production
PORT=5000

# Use the bundled MongoDB container, or replace with MongoDB Atlas/managed MongoDB.
MONGO_URI=mongodb://mongo:27017/livesale-fitness

JWT_SECRET=replace-with-a-long-random-secret
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=admin@livesale.fitness
SUPER_ADMIN_PASSWORD=replace-with-a-strong-password

FRONTEND_URL=https://livesale.fitness
ADMIN_FRONTEND_URL=https://admin.livesale.fitness
API_URL=https://api.livesale.fitness
CLIENT_ORIGINS=https://livesale.fitness,https://www.livesale.fitness,https://admin.livesale.fitness

# Vite build-time values for both frontends.
VITE_API_BASE_URL=https://api.livesale.fitness/api
VITE_API_URL=https://api.livesale.fitness/api
VITE_BASE_URL=https://api.livesale.fitness

# SMTP/email.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_USER=
EMAIL_PASS=
ADMIN_EMAIL=admin@livesale.fitness

# Cloudinary.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
